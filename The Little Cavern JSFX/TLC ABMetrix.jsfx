  gfx_setfont(1, "Arial", 20, "b"); gfx_x = gx_p + 50; gfx_y = ly_ov; gfx_drawstr("2. Create a Reference Track (REF)"); ly_ov += 40;
  gfx_setfont(1, "Arial", 18); gfx_x = gx_p + 70; gfx_y = ly_ov; gfx_drawstr("- On that track, verify \"Master send\" is checked."); ly_ov += 32;
  gfx_x = gx_p + 70; gfx_y = ly_ov; gfx_drawstr("- Set \"Master send channels from/to:\" from All to 3-4."); ly_ov += 32;
  gfx_x = gx_p + 70; gfx_y = ly_ov; gfx_drawstr("- Select \"Add new hardware output...\" and set it to 3/4.");
  
