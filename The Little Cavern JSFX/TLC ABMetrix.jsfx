(!show_guide && draw_btn(rx + 115, btn_y, 160, 30, 1, "RESET ANALYTICS", ba_r, ba_g, ba_b, 1, 1, 1)) ? ( reset_mix_stats(); reset_ref_stats(); a_blink_timer = 10; );

// Guide Overlay
show_guide ? (
  gfx_set(0, 0, 0, 0.85); gfx_rect(0, 0, gfx_w, gfx_h); gw_ov = 650; gh_ov = 450; gx_p = (gfx_w - gw_ov)/2; gy_p = (gfx_h - gh_ov)/2;
  draw_3d_panel(gx_p, gy_p, gw_ov, gh_ov, 0.12, 0.12, 0.12, 5);
  gfx_set(1, 1, 1, 1); gfx_setfont(1, "Arial", 22, "b"); t_str = "INSTRUCTIONS FOR A/B ROUTING"; gfx_measurestr(t_str, tw, th); gfx_x = gx_p + (gw_ov-tw)/2; gfx_y = gy_p + 35; gfx_drawstr(t_str);
  gfx_set(1, 0.5, 0, 0.8); gfx_rect(gx_p + 50, gfx_y + th + 10, gw_ov - 100, 2);
  gfx_set(1, 1, 1, 1); ly_ov = gy_p + 100; 
  gfx_setfont(1, "Arial", 18, "i"); gfx_x = gx_p + 50; gfx_y = ly_ov; gfx_drawstr("Suggested setup order:"); ly_ov += 45;
  gfx_setfont(1, "Arial", 20, "b"); gfx_x = gx_p + 50; gfx_y = ly_ov; gfx_drawstr("1. Configure the Master Track"); ly_ov += 40;
